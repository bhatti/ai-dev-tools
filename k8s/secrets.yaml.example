# Copy to secrets.yaml, fill in real values, then:
#   kubectl apply -f k8s/secrets.yaml
# DO NOT commit secrets.yaml to git.
#
# Claude settings — create from your working local file:
#   kubectl create secret generic claude-settings \
#     --from-file=settings.json=$HOME/.claude/settings.json \
#     -n ai-dev
# Then mount it in your job (see gh-pipeline-job.yaml):
#   volumes:
#     - name: claude-settings
#       secret:
#         secretName: claude-settings
#   volumeMounts:
#     - name: claude-settings
#       mountPath: /home/agent/.claude
#       readOnly: true
apiVersion: v1
kind: Secret
metadata:
  name: ai-dev-secrets
  namespace: ai-dev
type: Opaque
stringData:
  # GitHub
  GH_TOKEN: "ghp_YOUR_TOKEN_HERE"

  # Jira / Atlassian
  JIRA_EMAIL: "you@example.com"
  JIRA_API_TOKEN: "YOUR_JIRA_API_TOKEN"
  JIRA_BASE_URL: "https://yourorg.atlassian.net"
  JIRA_HOST: "yourorg.atlassian.net"

  # BitBucket
  BITBUCKET_USERNAME: "your-bb-username"
  BITBUCKET_WORKSPACE: "your-workspace"
  BITBUCKET_TOKEN: "YOUR_BB_APP_PASSWORD"

  # SSH private key (base64 or raw)
  ssh-key: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    REPLACE_WITH_YOUR_KEY
    -----END OPENSSH PRIVATE KEY-----
