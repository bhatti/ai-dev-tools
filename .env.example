# Copy to .env and fill in your values. Never commit .env.
#
# Env var prefixes — either form is accepted, longer form takes precedence:
#   GitHub:    GH_TOKEN  or  GITHUB_TOKEN
#   BitBucket: BB_REPO   or  BITBUCKET_REPO

# ── GitHub ────────────────────────────────────────────────────────────────────
GH_ORG=bhatti
GH_REPO=your-repo
GH_TOKEN=ghp_your_token_here
# Aliases (use either, not both):
# GITHUB_ORG=bhatti
# GITHUB_REPO=your-repo
# GITHUB_TOKEN=ghp_your_token_here

# ── Jira / Atlassian ──────────────────────────────────────────────────────────
JIRA_PROJECT=PROJ
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://yourorg.atlassian.net

# ── BitBucket ─────────────────────────────────────────────────────────────────
BITBUCKET_USERNAME=your-username
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_TOKEN=your_bb_app_password
BITBUCKET_REPO=your-repo
# Aliases (use either, not both):
# BB_USERNAME=your-username
# BB_WORKSPACE=your-workspace
# BB_TOKEN=your_bb_app_password
# BB_REPO=your-repo

# ── Claude / Bedrock ──────────────────────────────────────────────────────────
# Option A: Tailscale VPN / Bedrock proxy (no API key needed)
CLAUDE_CODE_USE_BEDROCK=1
# 'ai' resolves via extra_hosts in docker-compose.yml (Tailscale IP 100.107.120.55)
ANTHROPIC_BEDROCK_BASE_URL=http://ai/bedrock
CLAUDE_CODE_SKIP_BEDROCK_AUTH=1
ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6-v1
ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Option B: Anthropic API key directly (comment out Option A above)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

AI_MODEL=sonnet

# ── Workflow tuning ───────────────────────────────────────────────────────────
PICKUP_LABEL=ai-ready
INPROGRESS_LABEL=ai-in-progress
MAX_ISSUES=3
POLL_INTERVAL=120
